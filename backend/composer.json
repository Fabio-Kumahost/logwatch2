{
    "name": "logwatch2/panel",
    "description": "Logwatch2 central panel — log ingest, AI analysis, notifications",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-sodium": "*",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "twig/twig": "^3.10",
        "monolog/monolog": "^3.6",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": { "App\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "App\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "stan": "phpstan analyse src --level 5",
        "cs": "phpcs --standard=PSR12 --warning-severity=0 src"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
