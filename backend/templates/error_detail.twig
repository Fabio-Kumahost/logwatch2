{% extends "layout.twig" %}
{% block page %}error-detail{% endblock %}
{% block title %}Error #{{ group_id }} — Logwatch2{% endblock %}
{% block bodyattrs %}data-group-id="{{ group_id }}"{% endblock %}

{% block content %}
<section class="card">
  <div class="card-head">
    <h2 id="err-title">Error #{{ group_id }}</h2>
    <div class="actions">
      <button class="btn" data-status="acknowledged">Acknowledge</button>
      <button class="btn" data-status="resolved">Resolve</button>
      <button class="btn" data-status="ignored">Ignore (mute)</button>
      <button class="btn btn-primary" id="reanalyze-btn">Re-analyze</button>
    </div>
  </div>
  <div class="meta-row" id="err-meta"></div>
</section>

<section class="card" id="ai-card">
  <div class="card-head"><h2>🤖 AI analysis</h2><span class="muted" id="ai-meta"></span></div>
  <div id="ai-body" class="ai-body"><p class="muted">loading…</p></div>
</section>

<section class="card">
  <div class="card-head"><h2>Affected servers</h2></div>
  <ul class="server-list" id="err-servers"></ul>
</section>

<section class="card">
  <div class="card-head"><h2>Recent occurrences</h2></div>
  <div id="err-occurrences" class="occurrences"></div>
</section>
{% endblock %}
