# ------------------------------------------------------------------
# Logwatch2 environment — copy to .env and adjust.
# install.sh generates this file with random secrets automatically.
# NEVER commit the real .env.
# ------------------------------------------------------------------

# --- General ---
APP_ENV=production            # production | development
APP_URL=http://localhost:8080 # public URL of the panel (used in notification links)
PANEL_PORT=8080               # host port nginx listens on
PANEL_BIND=127.0.0.1          # bind address; 0.0.0.0 exposes the panel publicly
                              # (plain HTTP — prefer the TLS overlay or a reverse proxy)
TZ=Europe/Berlin

# 32-byte key, base64. Used to encrypt stored secrets (AI keys, webhook URLs).
# Generate: openssl rand -base64 32
APP_KEY=CHANGE_ME_BASE64_32_BYTES

# --- Database (the compose stack provisions PostgreSQL with these values) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=logwatch2
DB_USER=logwatch2
DB_PASSWORD=CHANGE_ME_RANDOM

# --- Sessions / auth ---
SESSION_LIFETIME=43200        # seconds (12h)
LOGIN_MAX_ATTEMPTS=5          # per 15 minutes per IP+user before temporary lockout

# --- Ingest limits ---
INGEST_MAX_BATCH=500          # max log entries per agent request
INGEST_MAX_BODY_KB=1024       # max request body size
AGENT_OFFLINE_AFTER=180       # seconds without heartbeat until server counts as offline

# --- AI (can also be configured in the panel UI; env wins if set) ---
AI_ENABLED=false
AI_PROVIDER=openai            # openai | anthropic | openai_compatible
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=                  # for openai_compatible, e.g. http://ollama:11434/v1
AI_MAX_TOKENS=1024
AI_DAILY_BUDGET_REQUESTS=500  # hard cap on AI calls per day (cost protection)

# --- Log retention ---
RETENTION_DAYS_LOGS=30        # raw log entries
RETENTION_DAYS_RESOLVED=90    # resolved error groups
AI_REANALYZE_AFTER_DAYS=30    # refresh stale analyses when the error recurs

# --- Security Radar (auth-attack detection, no AI cost) ---
RADAR_AUTH_THRESHOLD=20       # failed auth attempts per window → alert
RADAR_WINDOW_MINUTES=10
RADAR_SCAN_INTERVAL=120       # seconds between scans

# --- Anomaly detection (error-rate spikes vs 7-day baseline) ---
ANOMALY_MIN_ERRORS=10         # floor: ignore spikes below this many errors/hour

# --- Recurring-error thresholds ---
RECURRING_PER_HOUR=10
RECURRING_PER_DAY=50

# --- Prometheus metrics (optional) ---
METRICS_TOKEN=                # set to enable GET /metrics; scrape with "Authorization: Bearer <token>"
